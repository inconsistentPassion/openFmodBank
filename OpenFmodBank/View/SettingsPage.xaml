<Page x:Class="OpenFmodBank.View.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="24">
        <StackPanel MaxWidth="600">
            <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

            <ui:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="FMOD fsbankcl.exe Path"
                               FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Required for bank rebuilding. Auto-detected if placed in ./FMOD/ folder."
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding FsbankclPath, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button Grid.Column="1" Content="Browse" Appearance="Secondary" Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <ui:Card Padding="16">
                <ui:ToggleSwitch IsChecked="{Binding ForceOverwrite}"
                                  Content="Force Overwrite (skip confirmation)" />
            </ui:Card>
        </StackPanel>
    </Grid>

</Page>
