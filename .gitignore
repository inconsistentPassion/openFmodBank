.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# Rider
.idea/

# dotnet
*.DotSettings.user
launchSettings.json

# Runtime
*.log
*.tmp

# OS
.DS_Store
Thumbs.db
desktop.ini
