<ui:UiPage x:Class="OpenFmodBank.App.Views.MainView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
           xmlns:vm="clr-namespace:OpenFmodBank.App.ViewModels"
           xmlns:local="clr-namespace:OpenFmodBank.App.Views">

    <ui:UiPage.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InvertBooleanConverter x:Key="InvertBool" />
    </ui:UiPage.Resources>

    <ui:UiPage.DataContext>
        <vm:MainViewModel />
    </ui:UiPage.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="FMOD Bank Extractor &amp; Rebuilder"
                       FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Extract sounds from FMOD .bank files, modify them, and rebuild."
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- ═══ Path Configuration ═══ -->
        <ui:Card Grid.Row="1" Margin="0,0,0,16" Padding="20">
            <StackPanel>
                <TextBlock Text="Paths" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                <!-- Banks path -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Banks folder:"
                               VerticalAlignment="Center" FontWeight="Medium" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding BanksPath, UpdateSourceTrigger=PropertyChanged}"
                                IsReadOnly="{Binding IsBusy}"
                                VerticalAlignment="Center" />
                    <ui:Button Grid.Column="2" Content="Browse"
                               Appearance="Secondary"
                               Command="{Binding BrowseBanksCommand}"
                               Margin="8,0,0,0" />
                </Grid>

                <!-- Wavs path -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Output folder:"
                               VerticalAlignment="Center" FontWeight="Medium" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding WavsPath, UpdateSourceTrigger=PropertyChanged}"
                                IsReadOnly="{Binding IsBusy}"
                                VerticalAlignment="Center" />
                    <ui:Button Grid.Column="2" Content="Browse"
                               Appearance="Secondary"
                               Command="{Binding BrowseWavsCommand}"
                               Margin="8,0,0,0" />
                </Grid>

                <!-- Build path -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Build folder:"
                               VerticalAlignment="Center" FontWeight="Medium" />
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding BuildPath, UpdateSourceTrigger=PropertyChanged}"
                                IsReadOnly="{Binding IsBusy}"
                                VerticalAlignment="Center" />
                    <ui:Button Grid.Column="2" Content="Browse"
                               Appearance="Secondary"
                               Command="{Binding BrowseBuildCommand}"
                               Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </ui:Card>

        <!-- ═══ Action Buttons ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Content="Extract Sounds"
                       Icon="{ui:SymbolIcon ArrowDownload24}"
                       Appearance="Primary"
                       FontSize="15"
                       Padding="20,12"
                       Command="{Binding ExtractCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />

            <ui:Button Grid.Column="1"
                       Content="Rebuild Banks"
                       Icon="{ui:SymbolIcon ArrowUpload24}"
                       Appearance="Secondary"
                       FontSize="15"
                       Padding="20,12"
                       Command="{Binding RebuildCommand}"
                       IsEnabled="{Binding IsBusy}"
                       Margin="16,0,0,0" />
        </Grid>

        <!-- ═══ Progress ═══ -->
        <ui:Card Grid.Row="3" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Status text -->
                <TextBlock Grid.Row="0"
                           Text="{Binding StatusText}"
                           FontSize="13"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,8" />

                <!-- Progress bar -->
                <ui:ProgressBar Grid.Row="1"
                                IsIndeterminate="{Binding IsIndeterminate}"
                                Value="{Binding ProgressValue}"
                                Maximum="{Binding ProgressMaximum}"
                                Margin="0,0,0,12" />

                <!-- Console output -->
                <ui:TextBox Grid.Row="2"
                            IsReadOnly="True"
                            Text="{Binding ConsoleOutput, Mode=OneWay}"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalScrollBarVisibility="Auto"
                            FontFamily="Consolas"
                            FontSize="12"
                            MinHeight="120" />
            </Grid>
        </ui:Card>

        <!-- ═══ Status bar ═══ -->
        <TextBlock Grid.Row="4"
                   Text="{Binding ElapsedText}"
                   FontSize="11"
                   Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                   HorizontalAlignment="Right"
                   Margin="0,8,0,0" />
    </Grid>

</ui:UiPage>
